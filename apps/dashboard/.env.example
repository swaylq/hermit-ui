# --- hermit-ui dashboard ---
# Copy to `.env` and fill in. Never commit the real `.env` (it is gitignored).

# Postgres connection string used by Prisma. Required.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/hermit_ui"

# Port the Next.js custom server (server.ts) listens on. Default: 3000.
PORT=4101

# "production" on a server, "development" locally.
NODE_ENV=production

# Shared machine key the gateway presents to the dashboard's /api/sync routes.
# Must match HERMIT_KEY on the gateway. Stored hashed (bcrypt) in the DB; this
# value seeds/verifies a MachineKey row. Leave blank to disable sync auth in dev.
# HERMIT_KEY=

# Display name shown in the UI for the human operator. Optional.
# HERMIT_USER_NAME=

# Where uploaded images and the image cache are written. Optional — sensible
# defaults are used when unset.
# HERMIT_UPLOAD_DIR=
# HERMIT_IMAGE_CACHE_DIR=
