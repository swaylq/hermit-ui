#!/usr/bin/env bash
# secret — encrypted secrets accessor for the local agent fleet.
#
# Ships INSIDE hermit-ui (apps/gateway/scripts/secret/) so any machine that
# clones the repo can self-initialize with `secret init` — no manual file
# copying. See `secret init` and secrets-usage.md (both alongside this script).
#
#   Store:      ~/.claude/global-memory/secrets.age   (age ASCII-armor; CIPHERTEXT.
#               The .age extension is deliberately NOT in the gateway's @import
#               whitelist [global-memory.ts IMPORTABLE = .md/.markdown/.mdx/.txt],
#               so this file is NEVER injected into any agent's context.)
#   Master key: macOS Keychain, generic-password service "hermit-secrets-age".
#               Readable by every process of THIS user (so all agents can decrypt),
#               never written to disk in plaintext.
#   Recipient:  ~/.claude/hermit-secrets-recipient.txt  (age public key; not secret).
#
# The private key and the encrypted store are NEVER committed to the repo (it is
# public). `secret init` receives them once over STDIN; the repo only carries the
# CLI, the recipient PUBLIC key, and the usage doc.
#
# Safety contract (see asst/AGENTS.md "Token Safety"):
#   · `set` reads the value from STDIN — never argv (avoids ps / shell history).
#   · `exec` injects secrets into a child's ENV — they never hit stdout/transcript.
#   · `get`/`load` DO print values — only for human/manual use, warned at runtime.
#   · every read/write appends an audit line (timestamp, action, KEY name, caller
#     pid) to ~/.claude/secrets-audit.log — KEY NAMES ONLY, never values.
#
# bash 3.2 compatible (macOS system bash). Do not use bash-4 features.
set -euo pipefail

# Homebrew's bindir (Apple Silicon /opt/homebrew/bin, Intel /usr/local/bin) is
# frequently absent from a non-interactive / gateway-launched PATH, so brew-
# installed `age` fails to resolve and every command dies "age not installed"
# although it's right there (hit on the macmini nodes — the gateway-launched
# agent's PATH lacks it). Prepend the brew bindirs when /opt/homebrew/bin is
# missing — a no-op on a login shell that already has them, harmless if absent.
case ":$PATH:" in
  *:/opt/homebrew/bin:*) ;;
  *) PATH="/opt/homebrew/bin:/usr/local/bin:$PATH"; export PATH ;;
esac

CLAUDE_DIR="${CLAUDE_DIR:-$HOME/.claude}"
SECRETS="$CLAUDE_DIR/global-memory/secrets.age"
RECIPIENT_FILE="$CLAUDE_DIR/hermit-secrets-recipient.txt"
KC_SERVICE="${HERMIT_KC_SERVICE:-hermit-secrets-age}"
# Identity fallback for machines where Keychain isn't used: `security
# add-generic-password` needs an interactive GUI auth dialog, so it can't be
# scripted over SSH / on a fresh `git pull`. `secret init` therefore writes the
# private key to this mode-600 file, and decrypt prefers Keychain but falls back
# to it. (On the original Mac the key stays in Keychain — never on disk.)
IDENTITY_FILE="$CLAUDE_DIR/hermit-secrets-identity.txt"
AUDIT="$CLAUDE_DIR/secrets-audit.log"

die() { printf 'secret: %s\n' "$*" >&2; exit 1; }

# Resolve this script's real directory (following symlinks; bash-3.2, no readlink -f),
# so `init` can find its sibling recipient/usage files even when invoked via the
# ~/.local/bin/secret symlink.
_self_dir() {
  local src="$1" dir
  while [ -L "$src" ]; do
    dir=$(cd -P "$(dirname "$src")" >/dev/null 2>&1 && pwd)
    src=$(readlink "$src")
    case "$src" in /*) ;; *) src="$dir/$src" ;; esac
  done
  cd -P "$(dirname "$src")" >/dev/null 2>&1 && pwd
}

# audit <action> [key] — metadata only, NEVER the value.
audit() { printf '%s\t%-5s\t%s\tpid=%s\n' "$(date '+%Y-%m-%dT%H:%M:%S')" "$1" "${2:-}" "${PPID:-?}" >>"$AUDIT" 2>/dev/null || true; }

_recipient() { cat "$RECIPIENT_FILE" 2>/dev/null || die "recipient file missing: $RECIPIENT_FILE"; }

# _decrypt → KEY=VALUE lines on stdout. Missing store → empty (rc 0).
# Identity source, in order: (1) Keychain (dumped to a one-shot 600 temp, since
# age -d needs a file), else (2) the mode-600 identity file. die()s (rc!=0) on any
# failure so callers can refuse to overwrite a store they couldn't read.
_decrypt() {
  [ -f "$SECRETS" ] || return 0
  local idf="" tmp=""
  tmp=$(mktemp); chmod 600 "$tmp"
  if security find-generic-password -s "$KC_SERVICE" -w >"$tmp" 2>/dev/null && [ -s "$tmp" ]; then
    idf="$tmp"
  elif [ -f "$IDENTITY_FILE" ]; then
    rm -f "$tmp"; tmp=""; idf="$IDENTITY_FILE"
  else
    rm -f "$tmp"; die "no master key (Keychain svc $KC_SERVICE nor $IDENTITY_FILE) — run: secret init"
  fi
  if ! age -d -i "$idf" "$SECRETS" 2>/dev/null; then [ -n "$tmp" ] && rm -f "$tmp"; die "decrypt failed"; fi
  [ -n "$tmp" ] && rm -f "$tmp"
  return 0
}

# _encrypt: stdin (KEY=VALUE lines) → store, armor, mode 600, atomic.
_encrypt() {
  local r; r=$(_recipient)
  umask 077
  age -a -r "$r" -o "$SECRETS.tmp" || { rm -f "$SECRETS.tmp"; die "encrypt failed"; }
  mv "$SECRETS.tmp" "$SECRETS"; chmod 600 "$SECRETS"
}

valid_key() { case "$1" in ""|*[!A-Za-z0-9_]*) return 1;; *) return 0;; esac; }

usage() {
  cat >&2 <<'EOF'
secret — encrypted secrets for the local agent fleet
  secret init                         bootstrap THIS machine (key+store via stdin; see below)
  secret list                         list KEY names (no values)
  printf %s VALUE | secret set KEY     add/replace KEY (value from stdin, never argv)
  secret rm KEY                        remove KEY
  secret exec KEY [KEY...] -- cmd ...  run cmd with those KEYs in its env (nothing to stdout)
  secret exec -- cmd ...               run cmd with ALL secrets in its env
  secret get KEY                       print KEY's value to stdout  (⚠ humans only)
  secret load                          print `export KEY=VALUE` for eval  (⚠ humans only)

init stdin format (one-time, from a machine that already has the key):
  the age private key, then optionally:
    ==SECRETS-STORE==
    <armored secrets.age contents>
EOF
}

# secret init — make `secret` usable on this machine after a fresh `git pull`.
# Idempotent. Installs the public bits from the repo (CLI symlink, recipient,
# usage doc) and imports the shared private key + store supplied on STDIN.
do_init() {
  local force_key=0 force_store=0
  while [ $# -gt 0 ]; do
    case "$1" in
      --force-key) force_key=1 ;;
      --force-store) force_store=1 ;;
      *) die "init: unknown flag $1" ;;
    esac
    shift
  done

  command -v age >/dev/null 2>&1 || die "age not installed — run: brew install age, then re-run secret init"

  local dir; dir=$(_self_dir "${BASH_SOURCE[0]:-$0}")
  local repo_recipient="$dir/hermit-secrets-recipient.txt"
  local repo_usage="$dir/secrets-usage.md"
  [ -f "$repo_recipient" ] || die "init: recipient file not next to script ($repo_recipient) — incomplete checkout?"

  mkdir -p "$CLAUDE_DIR/global-memory"

  # 1. CLI on PATH: symlink ~/.local/bin/secret → this repo copy (so `git pull` updates it).
  mkdir -p "$HOME/.local/bin"
  local link="$HOME/.local/bin/secret" self="$dir/secret"
  if [ -L "$link" ] || [ ! -e "$link" ]; then
    ln -sfn "$self" "$link"
  elif [ "$(cd -P "$(dirname "$link")" && pwd)/$(basename "$link")" != "$self" ]; then
    # A real (non-symlink) file is there — back it up, then symlink.
    mv "$link" "$link.pre-init.$$" && ln -sfn "$self" "$link"
    printf 'secret init: backed up prior %s → %s.pre-init.%s\n' "$link" "$link" "$$" >&2
  fi

  # 2. recipient (public) + 3. usage doc — copy from repo (idempotent).
  cp "$repo_recipient" "$RECIPIENT_FILE"; chmod 600 "$RECIPIENT_FILE"
  [ -f "$repo_usage" ] && cp "$repo_usage" "$CLAUDE_DIR/global-memory/secrets-usage.md"

  # Read stdin once (key, optional store). Empty stdin is fine if key already present.
  local blob=""; if [ ! -t 0 ]; then blob=$(cat); fi
  local key="" store=""
  if [ -n "$blob" ]; then
    if printf '%s\n' "$blob" | grep -q '^==SECRETS-STORE==$'; then
      key=$(printf '%s\n' "$blob" | sed '/^==SECRETS-STORE==$/,$d')
      store=$(printf '%s\n' "$blob" | sed '1,/^==SECRETS-STORE==$/d')
    else
      key="$blob"
    fi
  fi
  key=$(printf '%s' "$key" | tr -d '\r' | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')

  # 4. master key. Prefer an existing Keychain entry (the original Mac); otherwise
  # write the mode-600 identity file from stdin. We do NOT call
  # `security add-generic-password` — it needs an interactive GUI auth dialog and
  # would hang over SSH / on a headless self-init. Key arrives via stdin, never argv.
  local have_kc=0
  security find-generic-password -s "$KC_SERVICE" -w >/dev/null 2>&1 && have_kc=1
  if [ "$have_kc" = 1 ] && [ "$force_key" != 1 ]; then
    printf 'secret init: master key already in Keychain (svc %s) ✓\n' "$KC_SERVICE" >&2
  elif [ -f "$IDENTITY_FILE" ] && [ "$force_key" != 1 ] && [ -z "$key" ]; then
    printf 'secret init: identity file already present (%s) ✓\n' "$IDENTITY_FILE" >&2
  elif [ -n "$key" ]; then
    case "$key" in
      AGE-SECRET-KEY-1*) : ;;
      *) die "init: stdin does not look like an age private key (AGE-SECRET-KEY-1…)" ;;
    esac
    ( umask 077; printf '%s\n' "$key" > "$IDENTITY_FILE" ); chmod 600 "$IDENTITY_FILE"
    printf 'secret init: master key written to %s (mode 600) ✓\n' "$IDENTITY_FILE" >&2
  else
    die "init: no key found (Keychain/identity file) and none on stdin — pipe the age private key in"
  fi
  unset key blob

  # 5. store (ciphertext) — place if provided and absent (don't clobber without --force-store).
  if [ -n "$store" ]; then
    if [ -f "$SECRETS" ] && [ "$force_store" != 1 ]; then
      printf 'secret init: store already present (use --force-store to replace) ✓\n' >&2
    else
      umask 077; printf '%s\n' "$store" > "$SECRETS"; chmod 600 "$SECRETS"
      printf 'secret init: store installed ✓\n' >&2
    fi
  fi
  unset store

  # 6. verify
  if [ -f "$SECRETS" ]; then
    local n; n=$(_decrypt | sed -n 's/^\([A-Za-z_][A-Za-z0-9_]*\)=.*/\1/p' | wc -l | tr -d ' ')
    printf 'secret init: OK — decrypts, %s key(s) in store. Try: secret list\n' "$n" >&2
  else
    printf 'secret init: OK — key in place, no store yet. Add secrets with: printf %%s VALUE | secret set KEY\n' >&2
  fi
}

command -v age >/dev/null 2>&1 || [ "${1:-}" = "init" ] || die "age not installed (brew install age)"

cmd="${1:-}"; [ $# -gt 0 ] && shift || true
case "$cmd" in
  init) do_init "$@" ;;

  list)
    audit list
    _decrypt | sed -n 's/^\([A-Za-z_][A-Za-z0-9_]*\)=.*/\1/p' | sort
    ;;

  get)
    key="${1:?usage: secret get KEY}"; valid_key "$key" || die "bad key: $key"; audit get "$key"
    printf 'secret: ⚠ value printed to stdout — prefer `secret exec` inside agents.\n' >&2
    _decrypt | sed -n "s/^${key}=//p" | head -1
    ;;

  set)
    key="${1:?usage: printf %s VALUE | secret set KEY}"
    valid_key "$key" || die "bad key name (allowed: A-Za-z0-9_): $key"
    audit set "$key"
    val=$(cat); val=${val%$'\n'}                 # value from STDIN, drop one trailing newline
    cur=""
    if [ -f "$SECRETS" ]; then cur=$(_decrypt) || die "refusing to write — decrypt of existing store failed"; fi
    filtered=$(printf '%s\n' "$cur" | grep -v "^${key}=" || true)
    { [ -n "$filtered" ] && printf '%s\n' "$filtered"; printf '%s=%s\n' "$key" "$val"; } | _encrypt
    printf 'secret: set %s ✓\n' "$key" >&2
    ;;

  rm)
    key="${1:?usage: secret rm KEY}"; valid_key "$key" || die "bad key: $key"; audit rm "$key"
    [ -f "$SECRETS" ] || die "store is empty"
    cur=$(_decrypt) || die "refusing to write — decrypt failed"
    filtered=$(printf '%s\n' "$cur" | grep -v "^${key}=" || true)
    { [ -n "$filtered" ] && printf '%s\n' "$filtered"; } | _encrypt
    printf 'secret: removed %s ✓\n' "$key" >&2
    ;;

  exec)
    keys=(); nkeys=0
    while [ $# -gt 0 ] && [ "$1" != "--" ]; do
      valid_key "$1" || die "bad key: $1"
      keys[nkeys]="$1"; nkeys=$((nkeys + 1)); shift
    done
    [ "${1:-}" = "--" ] || die "usage: secret exec KEY... -- cmd args"
    shift; [ $# -gt 0 ] || die "no command after --"
    if [ "$nkeys" -gt 0 ]; then audit exec "${keys[*]}"; else audit exec ALL; fi
    plain=$(_decrypt)
    if [ "$nkeys" -gt 0 ]; then
      i=0
      while [ "$i" -lt "$nkeys" ]; do
        k="${keys[i]}"
        line=$(printf '%s\n' "$plain" | grep "^${k}=" || true)
        [ -n "$line" ] || die "key not found: $k"
        export "$line"
        i=$((i + 1))
      done
    else
      while IFS= read -r line; do [ -n "$line" ] && export "$line"; done <<<"$plain"
    fi
    unset plain
    exec "$@"
    ;;

  load)
    audit load
    printf 'secret: ⚠ values printed for eval — humans only, not inside agents.\n' >&2
    _decrypt | sed -n "s/^\([A-Za-z_][A-Za-z0-9_]*\)=\(.*\)/export \1='\2'/p"
    ;;

  ""|-h|--help|help) usage; [ -z "$cmd" ] && exit 1; exit 0 ;;
  *) die "unknown command: $cmd (try: secret help)" ;;
esac
