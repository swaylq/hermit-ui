# --- hermit-ui gateway (runs on the machine hosting the agents) ---
# Copy to `.env` and fill in. Never commit the real `.env` (it is gitignored).

# URL of the dashboard this gateway pushes collected state to. Required.
DASHBOARD_URL="https://dash.example.com"

# Absolute path to the directory that holds agent workspaces. Required.
AGENTS_ROOT="/path/to/agents"

# Shared machine key for authenticating to the dashboard /api/sync routes.
# Must match HERMIT_KEY on the dashboard side. (ASST_KEY is accepted as a
# legacy alias.)
# HERMIT_KEY=

# Root of the Claude Code project dirs (usually ~/.claude/projects).
# Optional; defaults to a path under $HOME.
# PROJECTS_ROOT=
