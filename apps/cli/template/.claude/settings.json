{
  "permissions": {
    "allow": [
      "Bash",
      "Edit",
      "Glob",
      "Grep",
      "MultiEdit",
      "NotebookEdit",
      "NotebookRead",
      "Read",
      "Task",
      "ToolSearch",
      "TodoWrite",
      "WebFetch",
      "WebSearch",
      "Write",
      "Write({{AGENT_DIR}}/**)",
      "Write({{AGENT_DIR}}/.claude/**)",
      "Edit({{AGENT_DIR}}/**)",
      "Edit({{AGENT_DIR}}/.claude/**)",
      "Read({{AGENT_DIR}}/**)",
      "Read({{AGENT_DIR}}/.claude/**)",
      "mcp__playwright",
      "mcp__playwright-browser",
      "mcp__hermit"
    ]
  },
  "mcpServers": {
    "playwright-browser": {
      "command": "{{AGENT_DIR}}/scripts/playwright-mcp-launcher.sh",
      "args": []
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "{{AGENT_DIR}}/scripts/hook-block-askuserquestion.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "{{AGENT_DIR}}/scripts/hook-web-permission.sh",
            "timeout": 14400
          }
        ]
      }
    ]
  }
}
